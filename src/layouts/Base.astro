---
import '../styles/global.css';
import '../styles/motion.css';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const {
  title = 'Flightal — Operational visibility on every flight',
  description = 'FDM tells you what happened. Flightal tells you why. Complete operational visibility on every flight.',
  ogImage = '/og-image.jpg',
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site ?? 'https://flightal.com').toString();
const ogImageUrl = new URL(ogImage, Astro.site ?? 'https://flightal.com').toString();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="color-scheme" content="light" />
    <meta name="theme-color" content="#ffffff" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    {/* LCP image — preloaded so the browser can start fetching before
        the stylesheet parses and discovers it. */}
    <link
      rel="preload"
      as="image"
      href="/images/hermes-pink.jpg"
      fetchpriority="high"
    />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Flightal" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:url" content={canonical} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <meta name="generator" content={Astro.generator} />

    {/* Umami analytics — privacy-friendly, no cookies, EU-hosted. */}
    <script
      is:inline
      defer
      src="https://cloud.umami.is/script.js"
      data-website-id="76ccca8c-024c-4ff1-a005-7dd577f2d2de"
    ></script>

    {/* Structured data. Helps Google + LLMs build the entity graph for
        Flightal AB — founders, product, and website cross-linked by @id. */}
    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@graph': [
        {
          '@type': 'Person',
          '@id': 'https://flightal.com/#robert',
          name: 'Robert Andersson',
          jobTitle: 'Founder & CEO',
          worksFor: { '@id': 'https://flightal.com/#organization' },
          description:
            'Commercial pilot (CPL/IR/ME). Repeat founder with two exits.',
        },
        {
          '@type': 'Person',
          '@id': 'https://flightal.com/#patrik',
          name: 'Patrik Sjöberg',
          jobTitle: 'Flight Operations',
          worksFor: { '@id': 'https://flightal.com/#organization' },
          description:
            '13,000 flight hours. 737 captain. Former Saab chief instructor.',
        },
        {
          '@type': 'Person',
          '@id': 'https://flightal.com/#carl',
          name: 'Carl Westin',
          jobTitle: 'Human Factors Advisor',
          worksFor: { '@id': 'https://flightal.com/#organization' },
          description:
            'PhD candidate at Linköping University, researching Human-AI teaming. Active 737 captain.',
          affiliation: {
            '@type': 'CollegeOrUniversity',
            name: 'Linköping University',
          },
        },
        {
          '@type': 'Organization',
          '@id': 'https://flightal.com/#organization',
          name: 'Flightal AB',
          alternateName: 'Flightal',
          url: 'https://flightal.com',
          logo: 'https://flightal.com/Flightal.svg',
          email: 'info@flightal.com',
          description:
            'Flight safety platform that captures the operational context behind cockpit events — ATC communications, procedural adherence, crew CRM patterns, workload, and decision points — automatically, on every flight.',
          foundingLocation: { '@type': 'Place', name: 'Sweden' },
          areaServed: ['EU', 'US'],
          sameAs: ['https://www.linkedin.com/company/flightal'],
          founder: { '@id': 'https://flightal.com/#robert' },
          employee: [
            { '@id': 'https://flightal.com/#robert' },
            { '@id': 'https://flightal.com/#patrik' },
            { '@id': 'https://flightal.com/#carl' },
          ],
        },
        {
          '@type': 'WebSite',
          '@id': 'https://flightal.com/#website',
          url: 'https://flightal.com',
          name: 'Flightal',
          description,
          publisher: { '@id': 'https://flightal.com/#organization' },
          inLanguage: 'en',
        },
        {
          '@type': 'SoftwareApplication',
          '@id': 'https://flightal.com/#product',
          name: 'Flightal',
          applicationCategory: 'BusinessApplication',
          applicationSubCategory: 'Aviation Safety',
          operatingSystem: 'On-device, cockpit-integrated',
          description:
            'Operational visibility on every flight. Captures ATC communications, procedure and checklist adherence, crew CRM patterns, workload and stress indicators, and decision points — without pilot reporting or observers.',
          publisher: { '@id': 'https://flightal.com/#organization' },
          audience: {
            '@type': 'Audience',
            audienceType: 'Commercial aviation operators in the EU and US',
          },
        },
      ],
    })} />
  </head>
  <body>
    <slot />

    <script>
      const io = new IntersectionObserver(
        (entries) => {
          for (const entry of entries) {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible');
              io.unobserve(entry.target);
            }
          }
        },
        { threshold: 0.12, rootMargin: '0px 0px -8% 0px' }
      );

      for (const el of document.querySelectorAll('.reveal, .reveal-stagger')) {
        io.observe(el);
      }

      const parallaxEls = document.querySelectorAll<HTMLElement>('.parallax-slow');
      if (parallaxEls.length && !matchMedia('(prefers-reduced-motion: reduce)').matches) {
        let ticking = false;
        const update = () => {
          const vh = window.innerHeight;
          for (const el of parallaxEls) {
            // Walk the offset-parent chain to find this element's center in
            // document coords. offsetTop is layout-based and unaffected by
            // transforms, so this is safe to recompute each frame.
            let docCenter = el.offsetHeight / 2;
            let cursor: HTMLElement | null = el;
            while (cursor) {
              docCenter += cursor.offsetTop;
              cursor = cursor.offsetParent as HTMLElement | null;
            }
            // Translation goes through zero when the element is centered in
            // the viewport, so the parallax effect is local to each section
            // rather than runaway-scaling with absolute scroll depth.
            const delta = window.scrollY + vh / 2 - docCenter;
            el.style.transform = `translate3d(0, ${delta * -0.08}px, 0)`;
          }
          ticking = false;
        };
        window.addEventListener(
          'scroll',
          () => {
            if (!ticking) {
              requestAnimationFrame(update);
              ticking = true;
            }
          },
          { passive: true }
        );
        window.addEventListener('load', update);
        update();
      }
    </script>
  </body>
</html>
