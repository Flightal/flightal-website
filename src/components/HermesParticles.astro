---
/**
 * HermesParticles — particle "portrait" of the Hermes statue.
 *
 * Samples /images/hermes-light.png on the client, builds a particle field
 * mapped through a deep-navy → phosphor gradient, and renders it onto a
 * canvas that fills the hero background.
 *
 * Architecture is animation-ready: each particle carries home / target /
 * velocity fields and the render path runs through a `tick()` function.
 * For now the loop is *not* started — the field is drawn once on init and
 * on resize. To switch into boid mode later, call `startAnimation()` from
 * the exposed `window.hermesParticles` API and update `targetX/targetY`.
 */
---

<div class="hermes-particles parallax-slow" aria-hidden="true">
  <canvas class="hermes-canvas"></canvas>
</div>

<style>
  .hermes-particles {
    position: absolute;
    inset: 0;
    overflow: hidden;
    background: #060810;
    will-change: transform;
  }
  .hermes-canvas {
    display: block;
    width: 100%;
    height: 100%;
  }
</style>

<script>
  type Particle = {
    /** Anchor position in source-image pixel coords. */
    homeX: number;
    homeY: number;
    /** Current position in canvas-CSS pixel coords. */
    x: number;
    y: number;
    /** Animation target in canvas-CSS pixel coords. Equals home when idle. */
    targetX: number;
    targetY: number;
    /** Velocity for future boid integration. */
    vx: number;
    vy: number;
    /** Pre-baked rgba string for fast fillStyle. */
    color: string;
    /** Side length in CSS pixels. */
    size: number;
  };

  const SRC = '/images/hermes-light.png';
  const SAMPLE_STEP = 2;
  const OBJECT_POSITION_X = 0.7;
  const OBJECT_POSITION_Y = 0.5;
  const BG = '#060810';
  // Quantize sampled brightness into N bins so all particles within a bin
  // share a fillStyle string. Cuts state changes during render from O(particles)
  // down to O(BRIGHTNESS_BINS), which is what makes ~250k+ particles tractable.
  const BRIGHTNESS_BINS = 48;

  // Brightness → color gradient. Anchored to the site's dark + phosphor
  // palette; mid-tones cool through navy/teal so the marble reads as
  // "data-painted" rather than a recolored photo.
  const STOPS: Array<{ t: number; rgb: [number, number, number] }> = [
    { t: 0.0, rgb: [10, 14, 24] },
    { t: 0.25, rgb: [14, 36, 60] },
    { t: 0.5, rgb: [22, 90, 110] },
    { t: 0.7, rgb: [55, 175, 140] },
    { t: 0.88, rgb: [150, 240, 60] },
    { t: 1.0, rgb: [121, 255, 0] },
  ];

  function gradientLookup(t: number): [number, number, number] {
    if (t <= STOPS[0].t) return STOPS[0].rgb;
    if (t >= STOPS[STOPS.length - 1].t) return STOPS[STOPS.length - 1].rgb;
    for (let i = 0; i < STOPS.length - 1; i++) {
      if (t <= STOPS[i + 1].t) {
        const localT = (t - STOPS[i].t) / (STOPS[i + 1].t - STOPS[i].t);
        const a = STOPS[i].rgb;
        const b = STOPS[i + 1].rgb;
        return [
          Math.round(a[0] + (b[0] - a[0]) * localT),
          Math.round(a[1] + (b[1] - a[1]) * localT),
          Math.round(a[2] + (b[2] - a[2]) * localT),
        ];
      }
    }
    return STOPS[STOPS.length - 1].rgb;
  }

  async function init() {
    const root = document.querySelector<HTMLElement>('.hermes-particles');
    if (!root) return;
    const canvas = root.querySelector<HTMLCanvasElement>('canvas');
    if (!canvas) return;
    const ctx = canvas.getContext('2d');
    if (!ctx) return;

    // Load and sample source.
    const img = new Image();
    img.crossOrigin = 'anonymous';
    img.src = SRC;
    try {
      await new Promise<void>((res, rej) => {
        img.onload = () => res();
        img.onerror = () => rej(new Error('image load failed'));
      });
    } catch {
      return; // leave the dark background if image fails
    }

    const imgW = img.naturalWidth;
    const imgH = img.naturalHeight;
    const sampleCanvas = document.createElement('canvas');
    sampleCanvas.width = imgW;
    sampleCanvas.height = imgH;
    const sampleCtx = sampleCanvas.getContext('2d');
    if (!sampleCtx) return;
    sampleCtx.drawImage(img, 0, 0);
    const px = sampleCtx.getImageData(0, 0, imgW, imgH).data;

    // Pre-bake one rgba string per brightness bin → cheap to assign during render.
    const binnedColors: string[] = new Array(BRIGHTNESS_BINS);
    for (let i = 0; i < BRIGHTNESS_BINS; i++) {
      const t = i / (BRIGHTNESS_BINS - 1);
      const [r, g, b] = gradientLookup(t);
      binnedColors[i] = `rgba(${r},${g},${b},0.92)`;
    }

    const particles: Particle[] = [];
    for (let y = 0; y < imgH; y += SAMPLE_STEP) {
      for (let x = 0; x < imgW; x += SAMPLE_STEP) {
        const idx = (y * imgW + x) * 4;
        const sr = px[idx];
        const sg = px[idx + 1];
        const sb = px[idx + 2];
        // Luma-weighted brightness (Rec. 709).
        const b709 = (0.2126 * sr + 0.7152 * sg + 0.0722 * sb) / 255;

        // Permissive inclusion: mid-tones (≥0.25) always pass so the statue
        // body reads solid; dark grain thinned probabilistically; only the
        // truest blacks are dropped entirely.
        const keep =
          b709 > 0.025 &&
          Math.random() < Math.min(1, 0.18 + b709 * 3.2);
        if (!keep) continue;

        const bin = Math.min(
          BRIGHTNESS_BINS - 1,
          Math.floor(b709 * BRIGHTNESS_BINS),
        );
        const color = binnedColors[bin];

        // Sub-pixel jitter so the grain doesn't look like a fixed grid.
        const jx = (Math.random() - 0.5) * SAMPLE_STEP * 0.9;
        const jy = (Math.random() - 0.5) * SAMPLE_STEP * 0.9;
        // Brightest highlights occasionally get a slightly larger dot — gives
        // a subtle phosphor glow where the marble catches the light.
        const size = b709 > 0.78 && Math.random() < 0.18 ? 1.6 : 1;

        particles.push({
          homeX: x + jx,
          homeY: y + jy,
          x: 0,
          y: 0,
          targetX: 0,
          targetY: 0,
          vx: 0,
          vy: 0,
          color,
          size,
        });
      }
    }

    // Group by color string so render makes ~BRIGHTNESS_BINS fillStyle changes
    // rather than one per particle. Sort once at init.
    particles.sort((a, b) => (a.color === b.color ? 0 : a.color < b.color ? -1 : 1));

    let dpr = 1;
    let cssW = 0;
    let cssH = 0;
    let scale = 1;
    let offsetX = 0;
    let offsetY = 0;

    function recompute() {
      if (!ctx) return;
      const rect = root.getBoundingClientRect();
      cssW = rect.width;
      cssH = rect.height;
      dpr = window.devicePixelRatio || 1;
      canvas.width = Math.round(cssW * dpr);
      canvas.height = Math.round(cssH * dpr);
      canvas.style.width = cssW + 'px';
      canvas.style.height = cssH + 'px';
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);

      // object-fit: cover + object-position math.
      scale = Math.max(cssW / imgW, cssH / imgH);
      const drawW = imgW * scale;
      const drawH = imgH * scale;
      offsetX = (cssW - drawW) * OBJECT_POSITION_X;
      offsetY = (cssH - drawH) * OBJECT_POSITION_Y;

      for (const p of particles) {
        p.x = offsetX + p.homeX * scale;
        p.y = offsetY + p.homeY * scale;
        p.targetX = p.x;
        p.targetY = p.y;
      }
    }

    function render() {
      if (!ctx) return;
      ctx.fillStyle = BG;
      ctx.fillRect(0, 0, cssW, cssH);
      let lastColor = '';
      for (const p of particles) {
        if (p.color !== lastColor) {
          ctx.fillStyle = p.color;
          lastColor = p.color;
        }
        ctx.fillRect(p.x, p.y, p.size, p.size);
      }
    }

    // Animation hook. When boid mode is enabled, integrate forces here
    // (separation/cohesion/alignment + spring toward target) then render.
    let animating = false;
    let rafId = 0;
    function tick() {
      render();
      if (animating) {
        rafId = requestAnimationFrame(tick);
      }
    }

    function startAnimation() {
      if (animating) return;
      animating = true;
      tick();
    }
    function stopAnimation() {
      animating = false;
      cancelAnimationFrame(rafId);
    }

    recompute();
    tick();

    // Resize handling.
    let pending = false;
    const onResize = () => {
      if (pending) return;
      pending = true;
      requestAnimationFrame(() => {
        recompute();
        if (!animating) tick();
        pending = false;
      });
    };
    window.addEventListener('resize', onResize);
    window.addEventListener('load', () => {
      recompute();
      if (!animating) tick();
    });

    // Expose for the future animation layer to hook into.
    (window as any).hermesParticles = {
      particles,
      recompute,
      render,
      tick,
      startAnimation,
      stopAnimation,
    };
  }

  init();
</script>
