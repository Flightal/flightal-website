---
import FlightPath from './FlightPath.astro';
import Wordmark from './Wordmark.astro';
---

<section class="hero">
  <div class="hero-bg">
    <img
      class="parallax-slow"
      src="/images/hermes-light.png"
      alt=""
      width="1672"
      height="941"
      loading="eager"
      decoding="async"
      fetchpriority="high"
    />
    <div class="hero-bg-tint"></div>
  </div>

  <FlightPath />

  <header class="hero-nav container">
    <Wordmark inverted />
    <nav class="hero-nav-links">
      <a href="#problem">Problem</a>
      <a href="#captures">Capabilities</a>
      <a href="#team">Team</a>
      <a href="#contact" class="hero-nav-cta">Book a conversation</a>
    </nav>
  </header>

  <div class="hero-content container reveal-stagger">
    <h1 class="display hero-headline">
      Traditional FDM tells you what happened.<br />
      <span class="italic-emphasis">Flightal tells you why,</span> so you can do something about it.
    </h1>
    <p class="hero-subhead">Complete operational visibility on every flight.</p>
    <div class="hero-cta-row">
      <a href="#contact" class="cta">Book a conversation</a>
    </div>
  </div>

  <div class="hero-scroll" aria-hidden="true">
    <span class="hero-scroll-label">Scroll</span>
    <span class="hero-scroll-line"></span>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    min-height: 100svh;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    background: #060808;
    color: var(--bg-bone);
    isolation: isolate;
  }

  .hero-bg {
    position: absolute;
    inset: -8% 0 0 0;
    z-index: 0;
  }
  .hero-bg img {
    width: 100%;
    height: 108%;
    object-fit: cover;
    object-position: 70% center;
    filter: brightness(0.72) contrast(1.06) saturate(0.92);
  }
  .hero-bg-tint {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(90deg, rgba(6, 8, 8, 0.78) 0%, rgba(6, 8, 8, 0.45) 45%, rgba(6, 8, 8, 0.15) 75%, rgba(6, 8, 8, 0.05) 100%),
      linear-gradient(180deg, rgba(6, 8, 8, 0.35) 0%, rgba(6, 8, 8, 0.15) 30%, rgba(6, 8, 8, 0.25) 75%, rgba(6, 8, 8, 0.6) 100%),
      radial-gradient(ellipse at 18% 50%, rgba(184, 224, 36, 0.05), transparent 55%);
  }

  .hero-nav {
    position: relative;
    z-index: 2;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-block: 2rem;
  }
  .hero-nav-links {
    display: flex;
    align-items: center;
    gap: clamp(1rem, 2.5vw, 2rem);
    font-size: var(--t-small);
    color: rgba(242, 239, 232, 0.75);
  }
  .hero-nav-links a {
    transition: color 200ms ease;
  }
  .hero-nav-links a:hover {
    color: var(--bg-bone);
  }
  .hero-nav-cta {
    padding: 0.5rem 0.9rem;
    border: 1px solid rgba(242, 239, 232, 0.4);
    color: var(--bg-bone) !important;
  }
  .hero-nav-cta:hover {
    background: var(--accent-phosphor);
    color: var(--ink-strong) !important;
    border-color: var(--accent-phosphor);
  }
  @media (max-width: 720px) {
    .hero-nav-links a:not(.hero-nav-cta) {
      display: none;
    }
  }

  .hero-content {
    position: relative;
    z-index: 2;
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding-block: 4rem;
    max-width: 1280px;
  }

  .hero-headline {
    color: var(--bg-bone);
    max-width: 28ch;
    margin-bottom: 2rem;
  }
  .hero-headline .italic-emphasis {
    color: var(--accent-phosphor);
  }

  .hero-subhead {
    font-family: var(--font-body);
    font-size: var(--t-body-lg);
    color: rgba(242, 239, 232, 0.78);
    max-width: 40ch;
    margin-bottom: 2.5rem;
  }

  .hero-cta-row {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .hero-scroll {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    color: rgba(242, 239, 232, 0.6);
    font-size: var(--t-micro);
    letter-spacing: 0.24em;
    text-transform: uppercase;
  }
  .hero-scroll-line {
    width: 1px;
    height: 36px;
    background: linear-gradient(180deg, rgba(242, 239, 232, 0.6), transparent);
  }
  @media (max-width: 720px) {
    .hero-scroll { display: none; }
  }
</style>
