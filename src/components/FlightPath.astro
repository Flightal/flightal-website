---
// Thin animated flight-path line for hero background.
// 1px stroke, --accent-phosphor, fades in on load via stroke-dasharray draw.
---

<svg
  class="flightpath"
  viewBox="0 0 1200 600"
  preserveAspectRatio="none"
  aria-hidden="true"
  focusable="false"
>
  <path
    class="flightpath-line"
    d="M -20 470 Q 220 460 360 410 T 720 280 T 1080 130 L 1220 80"
  />
  <circle class="flightpath-marker" cx="1080" cy="130" r="3.5" />
  <circle class="flightpath-marker" cx="-20" cy="470" r="2" />
</svg>

<style>
  .flightpath {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 1;
  }
</style>
