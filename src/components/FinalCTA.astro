<section class="final section" id="contact">
  <div class="container-narrow">
    <div class="final-inner reveal">
      <h2 class="display final-headline">
        Want to see what your FDM has been <span class="italic-emphasis">missing?</span>
      </h2>
      <div class="final-cta-row">
        <a href="mailto:robert@flightal.com?subject=Flightal%20%E2%80%94%20Book%20a%20conversation" class="cta">
          Book a 30-minute conversation
        </a>
      </div>
      <p class="final-email">
        <a href="mailto:robert@flightal.com">robert@flightal.com</a>
      </p>
    </div>
  </div>
</section>

<style>
  .final {
    background: var(--bg-bone);
    text-align: center;
  }
  .final-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2.5rem;
  }
  .final-headline {
    max-width: 18ch;
    line-height: 1.02;
    color: var(--ink-strong);
  }
  .final-headline .italic-emphasis {
    color: var(--ink-strong);
  }
  .final-cta-row {
    display: flex;
  }
  .final-email {
    font-size: var(--t-small);
    color: var(--ink-mute);
    letter-spacing: 0.02em;
  }
  .final-email a:hover {
    color: var(--ink-strong);
    text-decoration: underline;
    text-underline-offset: 4px;
    text-decoration-color: var(--accent-phosphor);
    text-decoration-thickness: 2px;
  }
</style>
