---
interface Props {
  index: string;
  label: string;
  accent: 'phosphor' | 'runway' | 'pink';
  title: string;
  fdm: string;
  actual: string;
}

const { index, label, accent, title, fdm, actual } = Astro.props;

/**
 * Wrap V-speed subscripts (e.g. "Vref", "V1", "V2", "Vne") in a styled
 * <sub> so the trailing identifier renders subscripted + bold italic.
 *
 * Matches uppercase V followed by 1–4 lowercase letters OR 1–3 digits at
 * a word boundary — that excludes acronyms like "VMC" (uppercase) and
 * unrelated text starting with V.
 */
function fmtAviation(text: string): string {
  return text.replace(
    /\bV([a-z]{1,4}|\d{1,3})\b/g,
    'V<sub class="vspeed-sub">$1</sub>',
  );
}
---

<article class:list={['scenario-card', `accent-${accent}`, 'reveal']}>
  <header class="scenario-head">
    <span class="scenario-index">{index}</span>
    <span class="scenario-label">{label}</span>
  </header>

  <h3 class="h3 scenario-title">{title}</h3>

  <div class="scenario-cols">
    <div class="scenario-col">
      <p class="scenario-col-head">What FDM saw</p>
      <p class="scenario-col-body" set:html={fmtAviation(fdm)}></p>
    </div>
    <div class="scenario-col">
      <p class="scenario-col-head">What actually happened</p>
      <p class="scenario-col-body" set:html={fmtAviation(actual)}></p>
    </div>
  </div>
</article>

<style>
  .scenario-card {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    padding: clamp(2rem, 3vw, 2.5rem) clamp(1.5rem, 2.5vw, 2rem);
    background: var(--bg-bone);
    border: 1px solid var(--ink-hair);
    /* Thicker accent rail at the top — the card's main accent moment. */
    border-top: 6px solid var(--ink);
  }
  .scenario-card.accent-phosphor { border-top-color: var(--accent-phosphor); }
  .scenario-card.accent-runway { border-top-color: var(--accent-runway); }
  .scenario-card.accent-pink { border-top-color: var(--accent-pink); }

  .scenario-head {
    display: flex;
    align-items: center;
    gap: 0.85rem;
  }
  .scenario-index {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 0.9rem;
    color: var(--ink-mute);
    letter-spacing: 0.06em;
  }
  .scenario-label {
    font-family: var(--font-body);
    font-weight: 500;
    font-size: var(--t-micro);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    padding: 0.3rem 0.65rem;
    border-radius: 999px;
    color: var(--ink-strong);
  }
  .accent-phosphor .scenario-label { background: var(--accent-phosphor); }
  .accent-runway .scenario-label { background: var(--accent-runway); }
  .accent-pink .scenario-label { background: var(--accent-pink); color: var(--bg-bone); }

  .scenario-title {
    line-height: 1.1;
  }

  .scenario-cols {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    padding-top: 1.25rem;
    border-top: 1px solid var(--ink-hair);
    flex: 1;
  }

  .scenario-col-head {
    font-family: var(--font-body);
    font-weight: 500;
    font-size: var(--t-micro);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--ink-mute);
    margin-bottom: 0.5rem;
  }
  .scenario-col-body {
    font-size: var(--t-body);
    line-height: 1.55;
    color: var(--ink);
  }
  .scenario-col-body :global(.vspeed-sub) {
    font-style: italic;
    font-weight: 700;
    text-transform: uppercase;
  }
</style>
